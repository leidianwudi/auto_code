// ── 导出模块：logger.ac ──

export enum LogLevel {
  DEBUG = 0,
  INFO = 1,
  WARN = 2,
  ERROR = 3
}

export class Logger {
  public static function log(level: Number, message: String): Void {
    let prefix = "INFO";
    if (level == 0) { prefix = "DEBUG"; }
    else if (level == 2) { prefix = "WARN"; }
    else if (level == 3) { prefix = "ERROR"; }
    printLog(`[${prefix}] ${message}`);
  }
}