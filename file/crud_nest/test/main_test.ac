// ═══════════════════════════════════════════════════════════════
// 辅助函数
// ═══════════════════════════════════════════════════════════════

function assert(condition: Boolean, message: String): Void {
  if (!condition) {
    printLog(`断言失败: ${message}`);
  }
}

function tagTemplate(strings: String[], value1: String): String {
  // 简化版本：只支持一个插值变量
  let result = strings[0];
  if (value1 != null) {
    result = result + `[${value1}]` + strings[1];
  }
  return result;
}

function range(start: Number, end: Number): Number[] {
  let result: Number[] = [];
  let i = start;
  while (i < end) {
    result.push(i);
    i = i + 1;
  }
  return result;
}