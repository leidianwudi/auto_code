// 基础数学运算
function add(a: Number, b: Number): Number {
  return a + b;
}

function multiply(a: Number, b: Number): Number {
  return a * b;
}

function divide(a: Number, b: Number): Number {
  if (b == 0) {
    printLog("Error: Division by zero");
    return 0;
  }
  return a / b;
}

function power(base: Number, exp: Number): Number {
  let result = 1;
  for (let i: Number = 0; i < exp; i++) {
    result = result * base;
  }
  return result;
}

// 字符串处理函数
function greet(name: String, greeting: String): String {
  greeting = greeting || "Hello";  // 默认值替代方案
  return `${greeting}, ${name}! 欢迎使用 AutoCode`;
}

function formatNumber(num: Number, decimals: Number): String {
  decimals = decimals || 2;  // 默认值替代方案
  // 简单的数字格式化（不使用 toFixed）
  let str = "" + num;
  let dotPos = str.indexOf(".");
  if (dotPos == -1) {
    str = str + ".";
    for (let i = 0; i < decimals; i++) {
      str = str + "0";
    }
  } else {
    let decimalPart = str.substring(dotPos + 1);
    if (decimalPart.length > decimals) {
      // 截断到指定小数位
      str = str.substring(0, dotPos + 1 + decimals);
    } else {
      // 补零
      while (decimalPart.length < decimals) {
        str = str + "0";
        decimalPart = decimalPart + "0";
      }
    }
  }
  return str;
}

function capitalize(str: String): String {
  if (str.length == 0) return str;
  return str[0].toUpperCase() + str.substring(1);
}

function reverseString(str: String): String {
  let reversed = "";
  for (let ch: String in str) {
    reversed = ch + reversed;
  }
  return reversed;
}

// 数组工具函数
function filter(arr: Object[], predicate: Any): Object[] {
  let result: Any[] = [];
  for (let item: Any in arr) {
    if (predicate(item)) {
      result.push(item);
    }
  }
  return result;
}

function map(arr: Object[], transformer: Any): Object[] {
  let result: Any[] = [];
  for (let item: Any in arr) {
    result.push(transformer(item));
  }
  return result;
}

function reduce(arr: Object[], accumulator: Any, initialValue: Any): Any {
  let total: Any = initialValue;
  for (let item: Any in arr) {
    total = accumulator(total, item);
  }
  return total;
}

