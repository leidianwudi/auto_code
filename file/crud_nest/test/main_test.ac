  // ── 作用域测试 ──

  let outer = 100;
  if (true) {
    let outer = 200;
    let inner = 300;
    printLog("inner outer: " + outer);
    printLog("inner inner: " + inner);
  }
  printLog("outer after if: " + outer);

  let arrSum = 0;
  for (i in [1, 2, 3]) {
    let squared = i * i;
    arrSum = arrSum + squared;
  }
  printLog("sum of squares: " + arrSum);

  let flag = false;
  if (flag) {
    printLog("not executed");
  } else {
    let elseVar = "else block";
    printLog("elseVar: " + elseVar);
  }

  // ── 静态变量/函数测试 ──

  printError("--- 静态测试开始 ---");

  let initCount = Counter::count;
  printLog("初始静态 count: " + initCount);

  Counter::increment();
  let c1 = Counter::getCount();
  printLog("第一次自增后: " + c1);

  Counter::increment();
  let c2 = Counter::getCount();
  printLog("第二次自增后: " + c2);

  let finalCount = Counter::count;
  printLog("最终静态 count: " + finalCount);

  let name = Counter::name;
  printLog("静态名称: " + name);

  printLog("--- 静态测试结束 ---");
}