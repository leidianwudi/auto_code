// 基础用户类 - 演示封装和访问控制
class User implements Printable, Serializable {
  private let id: Any;
  protected let name: String;
  public let email: String;
  public let role: Any;
  public let createdAt: Number;

  public constructor(id: Any, name: String, email: String) {
    this.id = id;
    this.name = name;
    this.email = email;
    this.role = ROLE_GUEST;
    this.createdAt = 1705500000000;  // 使用固定时间戳替代 Date.now()
  }

  // Getter 和 Setter
  public function getName(): String {
    return this.name;
  }

  public function setName(name: String): Void {
    if (name.length < 2) {
      printLog("Error: Name too short");
      return;
    }
    this.name = name;
  }

  public function getId(): Number {
    return this.id;
  }

  // 接口实现
  public function toString(): String {
    return `User(${this.name}, ${this.email})`;
  }

  public function toDetailedString(): String {
    return `User[id=${this.id}, name=${this.name}, email=${this.email}, role=${this.role}]`;
  }

  public function toJson(): String {
    return `{"id":"${this.id}","name":"${this.name}","email":"${this.email}"}`;
  }

  public function fromJson(json: String): Void {
    let data: Object = JSON.parse(json);
    this.id = data["id"];
    this.name = data["name"];
    this.email = data["email"];
  }
}

// 管理员类 - 继承 User，演示继承和多态
class Admin extends User implements Comparable {
  private let permissions: String[];
  private let level: Number;

  public constructor(id: Any, name: String, email: String) {
    super(id, name, email);
    this.permissions = ["read", "write", "delete"];
    this.level = 1;
    this.role = UserRole.Admin;
  }

  public function addPermission(perm: String): Void {
    if (!this.permissions.includes(perm)) {
      this.permissions.push(perm);
    }
  }

  public function removePermission(perm: String): Void {
    let index = this.permissions.indexOf(perm);
    if (index >= 0) {
      this.permissions.splice(index, 1);
    }
  }

  public function hasPermission(perm: String): Bool {
    return this.permissions.includes(perm);
  }

  public function setLevel(level: Number): Void {
    if (level < 1 || level > 10) {
      printLog("Error: Level must be between 1 and 10");
      return;
    }
    this.level = level;
  }

  public function getLevel(): Number {
    return this.level;
  }

  // 实现 Comparable 接口
  public function compareTo(other: Any): Number {
    if (this.level > other.level) return 1;
    if (this.level < other.level) return -1;
    return 0;
  }

  public override function toString(): String {
    return `Admin[${this.name}, level=${this.level}, perms=${this.permissions.join(",")}]`;
  }
}

// 配置管理器 - 演示静态成员和单例模式
class ConfigManager {
  private static let instance: ConfigManager;
  private let settings: Object;

  private constructor() {
    this.settings = {};
  }

  public static function getInstance(): ConfigManager {
    if (ConfigManager.instance == null) {
      ConfigManager.instance = new ConfigManager();
    }
    return ConfigManager.instance;
  }

  public static function set(key: String, value: Any): Void {
    let mgr: ConfigManager = ConfigManager.getInstance();
    mgr.settings[key] = value;
    ConfigManager.instance = mgr;
  }

  public static function get(key: String): Any {
    let mgr: ConfigManager = ConfigManager.getInstance();
    return mgr.settings[key];
  }

  public static function getAll(): Object {
    let mgr: ConfigManager = ConfigManager.getInstance();
    // 手动复制对象（替代展开运算符）
    let copy: Object = {};
    for (let key: String in mgr.settings) {
      copy[key] = mgr.settings[key];
    }
    return copy;
  }

  public static function clear(): Void {
    let mgr: ConfigManager = ConfigManager.getInstance();
    mgr.settings = {};
    ConfigManager.instance = mgr;
  }

  public function loadFromJson(jsonStr: String): Void {
    this.settings = JSON.parse(jsonStr);
  }

  public function saveToJson(): String {
    return JSON.stringify(this.settings, null, 2);
  }
}

// 数据验证器 - 演示静态工具类（使用字符串方法替代正则表达式）
class Validator {
  // 简单的邮箱格式验证（检查是否包含 @ 和 .）
  public static function isEmail(email: String): Bool {
    if (email == null || email.length == 0) return false;
    let atPos = email.indexOf("@");
    if (atPos <= 0 || atPos == email.length - 1) return false;
    let dotPos: Number = email.lastIndexOf(".");
    if (dotPos <= atPos + 1 || dotPos == email.length - 1) return false;
    return true;
  }

  // 简单的手机号验证（检查是否为11位数字且以1开头）
  public static function isPhone(phone: String): Bool {
    if (phone == null || phone.length != 11) return false;
    if (phone[0] != "1") return false;
    // 检查第二位是否为3-9
    let secondChar = phone[1];
    if (secondChar < "3" || secondChar > "9") return false;
    // 检查剩余9位是否都是数字
    for (let i = 2; i < 11; i++) {
      let ch = phone[i];
      if (ch < "0" || ch > "9") return false;
    }
    return true;
  }

  // 简单的URL验证（检查是否以 http:// 或 https:// 开头）
  public static function isURL(url: String): Bool {
    if (url == null || url.length < 7) return false;
    let prefix = url.substring(0, 7);
    if (prefix == "http://") return true;
    if (url.length >= 8 && url.substring(0, 8) == "https://") return true;
    return false;
  }

  public static function minLength(str: String, min: Number): Bool {
    return str.length >= min;
  }

  public static function maxLength(str: String, max: Number): Bool {
    return str.length <= max;
  }

  public static function range(num: Number, min: Number, max: Number): Bool {
    return num >= min && num <= max;
  }
}

// 容器类 - 演示数据容器
class Container {
  private let items: Any[];

  public constructor() {
    this.items = [];
  }

  public function add(item: Any): Void {
    this.items.push(item);
  }

  public function remove(item: Any): Bool {
    let index = this.items.indexOf(item);
    if (index >= 0) {
      this.items.splice(index, 1);
      return true;
    }
    return false;
  }

  public function find(predicate: Any): Any {
    for (let item: Any in this.items) {
      if (predicate(item)) {
        return item;
      }
    }
    return null;  // 返回 null 替代 T | null
  }

  public function findAll(predicate: Any): Object[] {
    return filter(this.items, predicate);
  }

  public function count(): Number {
    return this.items.length;
  }

  public function clear(): Void {
    this.items = [];
  }

  public function toArray(): Object[] {
    // 手动复制数组（替代展开运算符）
    let copy: Any[] = [];
    for (let item: Any in this.items) {
      copy.push(item);
    }
    return copy;
  }
}

