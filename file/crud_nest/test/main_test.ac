// ── 接口定义 ──

interface Drivable {
  function drive(speed: Number): Void;
}

interface Printable {
  function toString(): String;
}

// ── 顶层函数 ──

function add(a: Number, b: Number): Number {
  return a + b;
}

function multiply(a: Number, b: Number): Number {
  return a * b;
}

function greet(name: String): String {
  return "Hello, " + name + "!";
}

// ── 类定义（带访问控制） ──

class Engine {
  private let type = "V8";
  protected let horsepower = 400;

  public function start(): Void {
    printLog("Engine " + this.type + " started, horsepower: " + this.horsepower);
  }

  public function getInfo(): String {
    return this.type + " (" + this.horsepower + "hp)";
  }
}

// ── 继承 ──

class Car extends Engine implements Drivable {
  public let brand = "Tesla";
  public let engine = new Engine();
  public let year = 2024;

  public override function start(): Void {
    super.start();
    printLog(this.brand + " engine started");
  }

  public function drive(speed: Number): Void {
    this.engine.start();
    printLog(this.brand + " is driving at " + speed + " km/h");
  }

  public function getDetails(): String {
    let info = this.engine.getInfo();
    return this.brand + " " + this.year + " with engine: " + info;
  }
}

class Person implements Printable {
  public let name = "default";
  private let age = 0;

  public function setName(n: String): Void {
    this.name = n;
  }

  public function setAge(a: Number): Void {
    this.age = a;
  }

  public function introduce(): String {
    return "Hi, I'm " + this.name + ", " + this.age + " years old";
  }

  public function toString(): String {
    return this.name + " (" + this.age + ")";
  }
}

// ── 静态类测试 ──

class Counter {
  static let count = 0;
  static let name = "Counter";

  static function increment(): Void {
    Counter::count = Counter::count + 1;
  }

  static function getCount(): Number {
    return Counter::count;
  }
}

// ── 主入口 ──

main {
  printLog(8);

  let sum = add(10, 20);
  printLog("sum: " + sum);

  let product = multiply(6, 7);
  printLog("product: " + product);

  let msg = greet("AutoCode");
  printLog(msg);

  // 使用带继承的类
  let myEngine = new Engine();
  myEngine.start();
  let engineInfo = myEngine.getInfo();
  printLog("Engine info: " + engineInfo);

  let myCar = new Car();
  myCar.start();
  myCar.drive(120);
  let details = myCar.getDetails();
  printLog("Car details: " + details);

  let person = new Person();
  person.setName("Alice");
  person.setAge(30);
  let intro = person.introduce();
  printLog(intro);

  // ── 数据库操作 ──

  let db = new DB({
    host: "192.168.5.103",
    port: 3306,
