// ── 顶层函数：在 main 外部定义，可以在 main 中调用 ──

function add(a, b) {
  
  return a + b;
}

function multiply(a, b) {
  return a * b;
}

function greet(name) {
  return "Hello, " + name + "!";
}

// ── 顶层类：在 main 外部定义 ──

class Engine {
  
  let type = "V8";
  let horsepower = 400;

  function start() {
    printLog("Engine " + type + " started, horsepower: " + horsepower);
  }

  function getInfo() {
    return type + " (" + horsepower + "hp)";
    
  }
}

class Car {
  let brand = "Tesla";
  let engine = new Engine();
  let year = 2024;

  function drive(speed) {
    engine.start();
    printLog(brand + " is driving at " + speed + " km/h");
  }

  function getDetails() {
    let info = engine.getInfo();
    return brand + " " + year + " with engine: " + info;
  }
}

class Person {
  let name = "default";
  let age = 0;

  function setName(n) {
    this.name = n;
  }

  function setAge(a) {
    this.age = a;
  }

  function introduce() {
    return "Hi, I'm " + this.name + ", " + this.age + " years old";
  }
}

// ── 静态类测试 ──

class Counter {
  static let count = 0
  static let name = "Counter"

  static function increment() {
    Counter::count = Counter::count + 1
  }

  static function getCount() {
    return Counter::count
  }
}

// ── 主入口 ──

main {
  
  //let a = readFile();
  // 调用顶层函数
  let sum = add(10, 20);
  printLog("sum: " + sum);

  let product = multiply(6, 7);
  printLog("product: " + product);

  let msg = greet("AutoCode");
  printLog(msg);

  // 使用顶层类
  let myEngine = new Engine();
  myEngine.start();
  let engineInfo = myEngine.getInfo();
  printLog("Engine info: " + engineInfo);

  let myCar = new Car();
  myCar.drive(1);
  myCar.drive(120);
  let details = myCar.getDetails();
  printLog("Car details: " + details);

  let person = new Person();
  person.setName("Alice");
  person.setAge(30);
  let intro = person.introduce();
  printLog(intro);

  // ── 数据库操作 ──

  let db = new DB({
    host: "192.168.5.103",
    port: 3306,
    user: "root",
    password: "123456",
    database: "news"
  });

  let basePath = "D:/output";

  let templates = [
    { tpl: "1.tpl", suffix: ".ts" },
    { tpl: "2.tpl", suffix: ".ts" },
  ];

  let files = getCheckedFiles();
  for (file in files) {
    let json = readJson(file);
    let schema = db.tableSchema({ table: json.modelName });
    let combined = merge(json, schema);
    let name = basename(file);

    for (cfg in templates) {
      combined["outputPath"] = basePath + "/" + name;
      let result = renderTpl(cfg.tpl, combined);
      if (result) {
        writeFile(combined["outputPath"], result);
      }
    }
  }

  db.disconnect();

  // ── 作用域测试 ──

  let outer = 100;
  if (true) {
    let outer = 200;
    let inner = 300;
    printLog("inner outer: " + outer);
    printLog("inner inner: " + inner);
  }
  printLog("outer after if: " + outer);

  let arrSum = 0;
  for (i in [1, 2, 3]) {
    let squared = i * i;
    arrSum = arrSum + squared;
  }
  printLog("sum of squares: " + arrSum);

  let flag = false;
  if (flag) {
    printLog("not executed");
  } else {
    let elseVar = "else block";
    printLog("elseVar: " + elseVar);
  }

  // ── 静态变量/函数测试 ──

  printError("--- 静态测试开始 ---");

  let initCount = Counter::count;
  printLog("初始静态 count: " + initCount);

  Counter::increment();
  let c1 = Counter::getCount();
  printLog("第一次自增后: " + c1);

  Counter::increment();
  let c2 = Counter::getCount();
  printLog("第二次自增后: " + c2);

  let finalCount = Counter::count;
  printLog("最终静态 count: " + finalCount);

  let name = Counter::name;
  printLog("静态名称: " + name);

  printLog("--- 静态测试结束 ---");
}